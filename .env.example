# ==============================================================================
# Gestion Locative - Configuration d'environnement
# ==============================================================================
# Copiez ce fichier vers .env.local pour le développement local
# IMPORTANT: Ne jamais commiter les fichiers .env contenant des vraies clés
# ==============================================================================

# ==============================================================================
# SUPABASE (Requis)
# ==============================================================================
# Variables publiques (exposées au client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# 🔒 Variable secrète (JAMAIS exposée au client - server-side uniquement)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Optionnel: pour les migrations via l'API Management
# SUPABASE_MANAGEMENT_API_TOKEN=sbp_xxxxx

# ==============================================================================
# CLOUDFLARE TURNSTILE (Anti-spam CAPTCHA)
# ==============================================================================
# Créer les clés sur https://dash.cloudflare.com/turnstile
# En dev, laisser vide pour désactiver (graceful degradation)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ==============================================================================
# APPLICATION
# ==============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 🔒 Clé maîtresse pour le chiffrement des clés API (server-side uniquement)
API_KEY_MASTER_KEY=votre-cle-de-32-caracteres-minimum

# 🔒 Secret pour authentifier les appels cron (Supabase pg_cron → API routes)
# Générer avec : openssl rand -hex 32
CRON_SECRET=votre-cron-secret-ici

# ==============================================================================
# OPENAI / IA (Optionnel)
# ==============================================================================
# 🔒 Clés secrètes (server-side uniquement)
OPENAI_API_KEY=sk-xxxxx

# Modèles personnalisés (optionnel)
# OPENAI_MODEL_INSTANT=gpt-4o-mini
# OPENAI_MODEL_THINKING=gpt-4o
# OPENAI_MODEL_PRO=gpt-4o

# ==============================================================================
# STRIPE (Paiements - Optionnel)
# ==============================================================================
# Variable publique
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# 🔒 Clés secrètes (server-side uniquement)
STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Add-ons Stripe Price IDs
# STRIPE_PRICE_SIGNATURES_PACK=price_xxxxx
# STRIPE_PRICE_STORAGE_20GB=price_xxxxx
# STRIPE_PRICE_SMS_UNIT=price_xxxxx
# STRIPE_PRICE_RAR_ELECTRONIC=price_xxxxx
# STRIPE_PRICE_ETAT_DATE=price_xxxxx

# ==============================================================================
# RESEND (Emails - Optionnel)
# ==============================================================================
# Provider runtime principal
EMAIL_PROVIDER=resend

# 🔒 Clé secrète (server-side uniquement)
RESEND_API_KEY=re_xxxxx
# Alias compatible avec certains scripts/services historiques
# EMAIL_API_KEY=re_xxxxx
# Source prioritaire pour l'adresse d'expédition runtime
# EMAIL_FROM=Talok <noreply@talok.fr>
# EMAIL_REPLY_TO=support@talok.fr
RESEND_FROM_EMAIL=Talok <noreply@talok.fr>
RESEND_REPLY_TO=support@talok.fr
# Optionnel : les valeurs RESEND_* restent supportées pour compatibilité
# Destinataire des messages du formulaire /contact (defaut : support@talok.fr)
# CONTACT_TO_EMAIL=support@talok.fr

# Clé interne pour les appels serveur -> /api/emails/send
# Générer avec : openssl rand -hex 32
INTERNAL_EMAIL_API_KEY=votre-cle-interne-email-ici

# En développement, les emails sont simulés tant que cette variable reste à false
EMAIL_FORCE_SEND=false

# ==============================================================================
# TWILIO (SMS - Optionnel)
# ==============================================================================
# 🔒 Clés secrètes (server-side uniquement)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+33xxxxxxxxx
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxx
# 🔒 Verify Service SID (requis pour les OTP) — créer dans la console Twilio > Verify
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pour le script de test : npx tsx scripts/test-sms.ts [numero] ou TEST_PHONE_NUMBER=+596...
# TEST_PHONE_NUMBER=+596696123456

# ==============================================================================
# SENTRY (Monitoring - Optionnel)
# ==============================================================================
# Variable publique (OK pour le client)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o123.ingest.sentry.io/xxxxx

# 🔒 DSN serveur (server-side uniquement — utilisé par sentry.server.config et sentry.edge.config)
SENTRY_DSN=https://xxxxx@o123.ingest.sentry.io/xxxxx

# 🔒 Token d'auth pour source maps et releases (server-side uniquement)
# SENTRY_AUTH_TOKEN=sntrys_xxxxx

# Organisation et projet Sentry (utilisés par withSentryConfig dans next.config.js)
SENTRY_ORG=talok
SENTRY_PROJECT=talok

# Activer Sentry en développement (optionnel, false par défaut)
# NEXT_PUBLIC_SENTRY_DEBUG=true

# ==============================================================================
# POSTHOG (Analytics - Optionnel)
# ==============================================================================
# Variables publiques (OK pour le client)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ==============================================================================
# LANGFUSE (AI Monitoring - Optionnel)
# ==============================================================================
# 🔒 Clés secrètes (server-side uniquement)
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxx
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ==============================================================================
# FIREBASE (Push notifications natives - Optionnel)
# ==============================================================================
# 🔒 Service account JSON stringifié (server-side uniquement)
# Requis pour envoyer des push FCM aux appareils Android/iOS (Capacitor)
# Générer dans : Firebase Console > Project Settings > Service Accounts > Generate new private key
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# ==============================================================================
# WEB PUSH (VAPID - Optionnel)
# ==============================================================================
# Clés VAPID pour les notifications push web (navigateur)
# Générer avec : npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BPxxxxx
# VAPID_PRIVATE_KEY=xxxxx
# VAPID_SUBJECT=mailto:support@talok.fr

# ==============================================================================
# SÉCURITÉ
# ==============================================================================
# 🔒 Secret dédié au flux sécurisé de reset mot de passe
# Générer avec : openssl rand -hex 32
# IMPORTANT: doit être DISTINCT de tout autre secret. Ne JAMAIS réutiliser JWT_SECRET.
PASSWORD_RESET_COOKIE_SECRET=remplacez-par-un-secret-unique-d-au-moins-32-caracteres

# 🔒 Secret dédié aux tokens QR de remise des clés (HMAC)
# Générer avec : openssl rand -hex 32
# IMPORTANT: la rotation de ce secret invalide tous les QR en circulation.
KEY_HANDOVER_SECRET=remplacez-par-un-secret-unique-d-au-moins-32-caracteres

# 🔒 Secret dédié aux tokens d'invitation à la signature (bail/EDL)
# Générer avec : openssl rand -hex 32
# IMPORTANT: la rotation invalide les liens d'invitation en circulation.
SIGNATURE_TOKEN_SECRET=remplacez-par-un-secret-unique-d-au-moins-32-caracteres

# 🔒 Secret pour les tokens CSRF (server-side uniquement)
# CSRF_SECRET=xxxxx

# ==============================================================================
# TESTS E2E (Développement uniquement)
# ==============================================================================
# Source unique de vérité utilisée par tests/e2e/helpers/credentials.ts.
# Les helpers refusent tout fallback hardcodé : un test sans creds échoue.
# E2E_OWNER_EMAIL=test@example.com
# E2E_OWNER_PASSWORD=TestPassword123!
# E2E_TENANT_EMAIL=tenant@example.com
# E2E_TENANT_PASSWORD=TestPassword123!
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=TestPassword123!

# ==============================================================================
# NETLIFY (Auto-configuré par Netlify)
# ==============================================================================
# NETLIFY=true (défini automatiquement sur Netlify)

# ==============================================================================
# NORDIGEN / GOCARDLESS (Open Banking DSP2)
# ==============================================================================
# Inscription : https://bankaccountdata.gocardless.com/
# NORDIGEN_SECRET_ID=your-secret-id
# NORDIGEN_SECRET_KEY=your-secret-key

# ==============================================================================
# ENEDIS SGE / DataConnect (Compteurs connectes - Electricite)
# ==============================================================================
# Inscription : https://datahub-enedis.fr/
# ENEDIS_API_URL=https://ext.hml.api.enedis.fr
# ENEDIS_CLIENT_ID=your-enedis-client-id
# ENEDIS_CLIENT_SECRET=your-enedis-client-secret
# ENEDIS_REDIRECT_URI=https://your-domain.com/api/oauth/enedis/callback

# ==============================================================================
# GRDF ADICT (Compteurs connectes - Gaz)
# ==============================================================================
# Inscription : https://api.grdf.fr/
# GRDF_API_URL=https://api.grdf.fr
# GRDF_CLIENT_ID=your-grdf-client-id
# GRDF_CLIENT_SECRET=your-grdf-client-secret
# GRDF_REDIRECT_URI=https://your-domain.com/api/oauth/grdf/callback

# ==============================================================================
# GOOGLE PLACES API (Recherche de prestataires nearby - optionnel)
# ==============================================================================
# Active la recherche réelle d'artisans autour d'un bien dans /owner/providers
# (Confort+) ainsi que le géocodage Google haute précision pour /api/geocode.
# Sans cette clé, l'app retombe sur :
#   - Nominatim (OpenStreetMap) pour le géocodage — gratuit
#   - Données de démonstration enrichies pour la liste des prestataires
# Voir docs/GOOGLE_PLACES_SETUP.md pour la procédure complète.
# Coût indicatif : 15-25€/mois pour ~100 propriétaires actifs (cache 24h).
# GOOGLE_PLACES_API_KEY=AIzaSy...

# Rate-limit Google Places (defense in depth contre l'epuisement du quota).
# Defaut sain : 30 appels/h et 200/jour par user, 60/h par IP. Ajuster a la
# baisse pour un controle plus strict ou si tu detectes du flood.
# GOOGLE_PLACES_LIMIT_PER_USER_HOUR=30
# GOOGLE_PLACES_LIMIT_PER_USER_DAY=200
# GOOGLE_PLACES_LIMIT_PER_IP_HOUR=60

# ==============================================================================
# IMPORT D'ANNONCES - Services anti-bot (optionnels)
# ==============================================================================
# Sans ces clés, /api/scrape utilise un fetch direct qui se fait bloquer par
# LeBonCoin / SeLoger / BienIci (DataDome). Avec une clé, la cascade essaie
# d'abord ScrapingBee puis Browserless avant le fetch direct.
#
# ScrapingBee : https://www.scrapingbee.com (~30€/mois pour 150k crédits)
# SCRAPINGBEE_API_KEY=
#
# Browserless v2 : https://www.browserless.io (~50€/mois)
# BROWSERLESS_API_KEY=
#
# Fallback LLM (OpenAI) : si l'extracteur rule-based échoue (score < 40 ou
# loyer/surface/ville tous absents), /api/scrape relit la page avec GPT-5.2
# Instant pour récupérer ce qui peut l'être. Réutilise OPENAI_API_KEY +
# OPENAI_MODEL_INSTANT déjà configurés plus haut. Coût indicatif : ~0.005 € /
# fallback. Sans OPENAI_API_KEY, le fallback est un no-op silencieux.
